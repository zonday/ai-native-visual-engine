{
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "rules": {
      "correctness": {
        "noUnusedVariables": "error"
      },
      "style": {
        "useConst": "error",
        "noNonNullAssertion": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/*/__tests__/**"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/core/src/runtime/handlers/**",
        "packages/core/src/document/handlers/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["./**"],
                    "message": "Handlers must not import from other handler files. Extract shared logic to a separate utility module outside the handlers/ directory."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ],
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "files": {
    "includes": [
      "packages/*/src/**",
      "packages/*/__tests__/**",
      ".github/**",
      "*.json",
      "*.yaml",
      "*.yml"
    ]
  }
}
