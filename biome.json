{
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "rules": {
      "correctness": {
        "noUnusedVariables": "error"
      },
      "style": {
        "useConst": "error"
      }
    }
  },
  "files": {
    "includes": ["packages/*/src/**", ".github/**", "*.json", "*.yaml", "*.yml", "*.md"]
  }
}
